CREATE TABLE Evento (
    id_evento INT NOT NULL PRIMARY KEY,
    nome_evento NVARCHAR(100) NOT NULL,
    data_evento DATE NOT NULL,
    local_evento NVARCHAR(100) NULL,
    capacidade INT CHECK (capacidade > 0)
);

CREATE TABLE Participante (
    id_participante INT PRIMARY KEY IDENTITY(1,1),
    nome NVARCHAR(100) NOT NULL,
    email NVARCHAR(100) NOT NULL UNIQUE,
    telefone NVARCHAR(20) NULL
);

CREATE TABLE Inscricao (
    id_inscricao INT PRIMARY KEY IDENTITY(1,1),
    id_evento INT NOT NULL,
    id_participante INT NOT NULL,
    status NVARCHAR(20) CHECK (status IN ('Ativa', 'Cancelada')),
    data_inscricao DATE DEFAULT GETDATE(),
    FOREIGN KEY (id_evento) REFERENCES Evento(id_evento),
    FOREIGN KEY (id_participante) REFERENCES Participante(id_participante)
);

CREATE TABLE Pagamento (
    id_pagamento INT PRIMARY KEY IDENTITY(1,1),
    id_inscricao INT NOT NULL,
    valor DECIMAL(10,2) CHECK (valor > 0),
    status NVARCHAR(20) CHECK (status IN ('Pendente', 'Confirmado')),
    data_pagamento DATE,
    FOREIGN KEY (id_inscricao) REFERENCES Inscricao(id_inscricao)
);

CREATE TABLE Palestra (
    id_palestra INT PRIMARY KEY IDENTITY(1,1),
    id_evento INT NOT NULL,
    titulo NVARCHAR(100) NOT NULL,
    palestrante NVARCHAR(100) NOT NULL,
    horario TIME NOT NULL,
    FOREIGN KEY (id_evento) REFERENCES Evento(id_evento)
);

